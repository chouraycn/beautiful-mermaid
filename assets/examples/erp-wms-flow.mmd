graph TD
    START([开始]) --> ERP1[采购订单创建]
    ERP1 --> WMS1[入库单接收]
    WMS1 --> WMS2{库存检查}
    WMS2 -->|有库存| ERP2[订单分配]
    WMS2 -->|无库存| ERP3[采购申请]
    ERP3 --> ERP1
    ERP2 --> WMS3[拣货任务生成]
    WMS3 --> WMS4[拣货中]
    WMS4 --> WMS5[包装检验]
    WMS5 --> WMS6{检验通过?}
    WMS6 -->|是| WMS7[出库扫描]
    WMS6 -->|否| WMS8[异常处理]
    WMS8 --> WMS4
    WMS7 --> ERP4[发货通知]
    ERP4 --> TMS1[物流调度]
    TMS1 --> TMS2[在途跟踪]
    TMS2 --> TMS3{签收确认}
    TMS3 -->|是| ERP5[完成收货]
    TMS3 -->|否| TMS4[异常签收]
    TMS4 --> TMS2
    ERP5 --> ERP6[财务结算]
    ERP6 --> FIN1[发票生成]
    FIN1 --> FIN2{付款确认}
    FIN2 -->|已付| END([流程结束])
    FIN2 -->|未付| ERP7[催款处理]
    ERP7 --> FIN2
